{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "jsxImportSource": "astro",
    "importsNotUsedAsValues": "remove",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "strict": true,
    "baseUrl": ".",
    "types": ["astro/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.astro"]
}
