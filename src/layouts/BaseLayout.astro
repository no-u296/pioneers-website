---
import '../styles/global.css';
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/events', label: 'Events' },
  { href: '/magazine', label: 'Magazine' }
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Math Club Pioneers</title>
    <meta name="description" content="Pioneers is the mathematics club of IIIT-B — where curiosity meets rigour through events, competitions, and a magazine." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <slot name="head" />
  </head>
  <body>
    <div class="relative overflow-hidden">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-72 bg-[radial-gradient(circle_at_top,_rgba(20,184,166,0.14),_transparent_40%)]" />
      <header class="relative z-20 mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6 text-sm md:px-8">
        <a href="/" class="flex items-center gap-4 font-semibold tracking-[0.18em] text-slate-100">
          <img src="/Logo.jpeg" alt="Pioneers logo" class="h-12 w-12 rounded-3xl border border-white/15 object-cover bg-slate-950/80" />
          <div class="space-y-1 text-left">
            <p class="text-sm uppercase tracking-[0.32em] text-cyan-200/90">Pioneers</p>
            <p class="text-xs uppercase text-slate-400">IIIT-B Math Club</p>
          </div>
        </a>

        <div class="hidden items-center gap-8 md:flex">
          <nav class="flex items-center gap-8">
            {navLinks.map((item) => (
              <a href={item.href} class="transition hover:text-cyan-200/95">{item.label}</a>
            ))}
          </nav>
          <div class="flex items-center">
            <img src="/IIITB.png" alt="IIIT-B logo" class="h-12 w-auto" />
          </div>
        </div>

        <button id="menu-toggle" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-slate-950/90 text-slate-100 transition hover:border-accent/40 hover:text-accent md:hidden" aria-label="Toggle navigation">
          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </header>

      <div id="mobile-menu" class="hidden border-t border-white/10 bg-slate-950/95 px-6 py-5 text-sm md:hidden">
        <div class="flex flex-col gap-4">
          {navLinks.map((item) => (
            <a href={item.href} class="block rounded-2xl px-4 py-3 transition hover:bg-white/5">{item.label}</a>
          ))}
        </div>
      </div>

      <main class="relative z-10 overflow-hidden">
        <slot />
      </main>

      <footer class="relative mx-auto mt-20 max-w-6xl px-6 pb-12 text-sm text-slate-400 md:px-8">
        <div class="flex flex-col gap-4 border-t border-white/10 pt-8 text-slate-400 md:flex-row md:items-center md:justify-between">
          <p>Math Club Pioneers — IIIT-B</p>
          <p class="text-slate-500">Curiosity, rigour, and community for every problem solver.</p>
        </div>
      </footer>
    </div>

    <script is:inline>
      const toggle = document.querySelector('#menu-toggle');
      const menu = document.querySelector('#mobile-menu');
      if (toggle && menu) {
        toggle.addEventListener('click', () => {
          menu.classList.toggle('hidden');
          menu.classList.toggle('block');
        });
      }
    </script>
  </body>
</html>
