---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>
  <section class="mx-auto max-w-5xl px-6 py-20 text-slate-100 md:px-8">
    <div class="rounded-[2rem] border border-white/10 bg-slate-950/80 p-10 shadow-glow">
      <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-sm uppercase tracking-[0.4em] text-cyan-300/80">About Us</p>
          <h1 class="mt-4 text-4xl font-semibold text-white md:text-5xl">Meet the team behind Pioneers at IIIT-B.</h1>
        </div>
        <div class="flex items-center gap-4">
          <img src="/Logo.jpeg" alt="Pioneers logo" class="h-20 w-20 rounded-3xl border border-white/10 object-cover" />
          <img src="/IIITB.png" alt="IIIT-B logo" class="h-16 w-auto" />
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <article class="space-y-4 rounded-[1.75rem] border border-white/10 bg-white/5 p-8">
          <p class="text-xs uppercase tracking-[0.35em] text-cyan-300/80">Founder</p>
          <h2 class="text-2xl font-semibold text-white">NAME 1</h2>
          <p class="text-slate-300 leading-7">
            Responsible for the club's vision and leadership, ensuring that Pioneers continues to grow as a strong mathematics community at IIIT-B.
          </p>
        </article>
        <article class="space-y-4 rounded-[1.75rem] border border-white/10 bg-white/5 p-8">
          <p class="text-xs uppercase tracking-[0.35em] text-cyan-300/80">Mathematics & Problem Solving</p>
          <h2 class="text-2xl font-semibold text-white">NAME 2</h2>
          <p class="text-slate-300 leading-7">
            Leads mathematical content, problem curation, and training resources for members who want to sharpen their reasoning and competition skills.
          </p>
        </article>
        <article class="space-y-4 rounded-[1.75rem] border border-white/10 bg-white/5 p-8">
          <p class="text-xs uppercase tracking-[0.35em] text-cyan-300/80">Club Management</p>
          <h2 class="text-2xl font-semibold text-white">XYZ</h2>
          <p class="text-slate-300 leading-7">
            Coordinates club operations, membership engagement, and the planning of sessions to keep the club running smoothly.
          </p>
        </article>
        <article class="space-y-4 rounded-[1.75rem] border border-white/10 bg-white/5 p-8">
          <p class="text-xs uppercase tracking-[0.35em] text-cyan-300/80">Finances</p>
          <h2 class="text-2xl font-semibold text-white">ABC</h2>
          <p class="text-slate-300 leading-7">
            Manages budgeting, event funding, and resource allocation so the club can support activities and publications effectively.
          </p>
        </article>
        <article class="space-y-4 rounded-[1.75rem] border border-white/10 bg-white/5 p-8 lg:col-span-2">
          <p class="text-xs uppercase tracking-[0.35em] text-cyan-300/80">Social Media</p>
          <h2 class="text-2xl font-semibold text-white">NAME 5</h2>
          <p class="text-slate-300 leading-7">
            Handles the club's online presence, communication, and outreach to keep members and the IIIT-B community informed and engaged.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
