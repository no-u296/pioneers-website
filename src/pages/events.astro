---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>
  <section class="mx-auto max-w-4xl px-6 py-20 text-slate-100 md:px-8">
    <div class="rounded-[2rem] border border-white/10 bg-slate-950/80 p-16 text-center shadow-glow">
      <p class="text-sm uppercase tracking-[0.4em] text-cyan-300/80">Events</p>
      <h1 class="mt-6 text-4xl font-semibold text-white md:text-5xl">Events page coming soon.</h1>
      <p class="mt-6 max-w-2xl mx-auto text-slate-300 leading-8">
        We are building the events section for Pioneers at IIIT-B. Check back soon for upcoming competitions, workshops, and problem-solving sessions.
      </p>
    </div>
  </section>
</BaseLayout>
