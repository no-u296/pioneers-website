---
const { href = '#', class: classes = '', variant = 'primary' } = Astro.props;
const base = 'inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-accent/60';
const style = variant === 'secondary'
  ? 'bg-white/5 text-slate-100 border border-white/10 hover:bg-white/10'
  : 'bg-brand text-slate-950 hover:bg-accent';
---
<a href={href} class={`${base} ${style} ${classes}`}>
  <slot />
</a>
